


---   Problem 5 : Get All Makes that have manufactured more than 12000 Vehicles in years 1950 to 2000

select  m.Make,  NumberOfVehicle=count(*) 
from VehicleMasterDetails v
join makes m
on v.MakeID = m.MakeID
where year between 1950 and 2000
group by m.Make
having COUNT(*)>12000
order by NumberOfVehicle desc;

-- 2
select * 
from (
select mk.Make,Count(*) as NumberOfVehicle from VehicleDetails v 
join Makes mk
on v.MakeID=mk.MakeID
where v.Year between 1950 and 2000
group by mk.Make
 ) r1

where r1.NumberOfVehicle>12000
order by r1.NumberOfVehicle desc
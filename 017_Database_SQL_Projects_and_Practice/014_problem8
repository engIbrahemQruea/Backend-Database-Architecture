

---   Problem 8: Get Make, FuelTypeName and Number of Vehicles per FuelType per Make
select m.Make,ft.FuelTypeName, NumberOfVehicle=count(*)
from VehicleDetails v
join Makes m
on v.MakeID=m.MakeID
join FuelTypes ft
on v.FuelTypeID=ft.FuelTypeID
where (year between 1950 and 2000)
group by m.Make,ft.FuelTypeName 
order by Make


select make,FuelTypeName, count(*) NumberOfVehicles
from vehicleMasterDetails
group by make,FuelTypeName
order by Make;


---   Problem 4 : Get number vehicles made between 1950 and 2000 per make and order them by Number Of Vehicles Descending

--- 1
select mk.Make,Count(*) as NumberOfVehicle from VehicleDetails v 
join Makes mk
on v.MakeID=mk.MakeID
where v.Year between 1950 and 2000
group by mk.Make
order by NumberOfVehicle desc

--- 2
select  m.Make, count(*) as NumberOfVehicle
from VehicleMasterDetails v
join makes m
on v.MakeID = m.MakeID
where year between 1950 and 2000
group by m.Make
order by count(*) desc;